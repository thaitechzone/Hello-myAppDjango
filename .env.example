# ========================================
# Environment Variables สำหรับ Docker
# คัดลอกไฟล์นี้เป็น .env และแก้ไขค่าตามต้องการ
# ========================================

# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-min-50-characters-change-in-production-abc123
DJANGO_SETTINGS_MODULE=smartfarm.settings_docker
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,yourdomain.com

# Database (PostgreSQL)
POSTGRES_DB=smartfarm
POSTGRES_USER=smartfarm_user
POSTGRES_PASSWORD=your-strong-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Database URL (Alternative)
DATABASE_URL=postgresql://smartfarm_user:your-strong-password-here@db:5432/smartfarm

# Security (Production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# CORS (ถ้ามี Frontend แยก)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Redis Cache (Optional)
# REDIS_URL=redis://redis:6379/0

# Email Configuration (Optional)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (Optional - for static/media files)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=ap-southeast-1

# Logging
DJANGO_LOG_LEVEL=INFO
